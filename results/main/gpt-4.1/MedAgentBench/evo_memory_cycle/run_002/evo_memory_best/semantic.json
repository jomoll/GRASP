  "rules": [
    "[P1] Do not proceed with contingent actions if required data or context is missing",
    "[P1] Do not fabricate or infer values or clinical/demographic data not present in context",
    "[P1] Request clarification or indicate missing information when context is insufficient",
    "[P1] Extract and confirm all required values, measurements, and identifiers from the provided context before proceeding",
    "[P1] Check if values meet recency or threshold criteria before finalizing actions",
    "[P1] When instructions include multiple independent actions, attempt all feasible steps even if one cannot be completed",
    "[P1] Confirm patient identifiers before performing or documenting clinical actions"
  ],
